NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-CC5FJRFNFS
GA4_API_SECRET=
GA4_MEASUREMENT_PROTOCOL_REGION=global

# SMTP transactional email
MAIL_SMTP_HOST=mail.life-kline.com
MAIL_SMTP_HOST_IP=180.97.70.166
MAIL_SMTP_PORT=25
MAIL_SMTP_SECURE=false
MAIL_SMTP_IGNORE_TLS=true
MAIL_FROM=admin@life-kline.com
MAIL_PASSWORD=
MAIL_FROM_NAME=人生K线
EMAIL_APP_NAME=人生K线
NEXT_PUBLIC_APP_URL=https://www.life-kline.com
ENABLE_AGENTIC_PIPELINE=1
DEFAULT_MODEL=gpt-5.2
# v5-A5 (2026-05-09): 实测翻盘 — gpt-5.2 真实报告 prompt 17-18s 稳成（直连），grok-420-fast 30s+ timeout
# 颠倒主备；ANALYZE 同步路径只用单 fallback (grok)，content/agent 异步路径可加 auto 当三兜底
MODEL_FALLBACK_CHAIN=grok-420-fast
CONTENT_GENERATION_MODEL=gpt-5.2
CONTENT_GENERATION_MODEL_FALLBACK_CHAIN=grok-420-fast,auto
CONTENT_GENERATION_MAX_TOKENS=2200
CONTENT_GENERATION_SOCRATIC_ENABLED=1
CONTENT_GENERATION_SEGMENTED_ENABLED=1
CONTENT_GENERATION_TIMEOUT_MS=180000
CONTENT_GENERATION_CRON_TOKEN=
CONTENT_GENERATION_JOB_RUN_URL=http://127.0.0.1:3000/api/admin/content/generate/cron
CONTENT_GENERATION_JOB_INTERVAL_MS=60000
CONTENT_GENERATION_JOB_REQUEST_TIMEOUT_MS=900000
CONTENT_GENERATION_JOB_STARTUP_DELAY_MS=15000
CONTENT_GENERATION_JOB_RETRY_DELAY_MS=60000
CONTENT_GENERATION_JOB_MAX_ATTEMPTS=3
CONTENT_GENERATION_JOB_BATCH_SIZE=1
CONTENT_GENERATION_JOB_STALE_LOCK_MINUTES=40
LLM_HEALTH_WINDOW_MINUTES=15
# v5-A5d (2026-05-09): 熔断阈值放宽 — 之前 v5-A2 太敏感（IMMEDIATE_OPEN=2 + CONSECUTIVE=3）
# 多并发 agent 同时失败时雪崩（一次失败立刻 OPEN 后续全拒），现在调宽 + 冷却 4→2 分钟
LLM_CIRCUIT_OPEN_MIN_ATTEMPTS=5
LLM_CIRCUIT_OPEN_FAILURE_RATE=0.7
LLM_CIRCUIT_DEGRADE_FAILURE_RATE=0.50
LLM_CIRCUIT_RECOVER_FAILURE_RATE=0.30
LLM_CIRCUIT_OPEN_CONSECUTIVE_FAILURES=5
LLM_CIRCUIT_IMMEDIATE_OPEN_CONSECUTIVE_FAILURES=4
LLM_CIRCUIT_RECOVERY_SUCCESS_STREAK=1
LLM_CIRCUIT_OPEN_COOLDOWN_MINUTES=2
REPORT_UPGRADE_MAX_ATTEMPTS=4

# Visual asset image generation
VISUAL_ASSET_API_BASE_URL=https://www.gemiai.top/v1
