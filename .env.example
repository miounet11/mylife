# Auth / email
AUTH_SHOW_CODE=false
ADMIN_EMAILS=admin@example.com

# SMTP transactional email
MAIL_SMTP_HOST=mail.life-kline.com
MAIL_SMTP_HOST_IP=180.97.70.166
MAIL_SMTP_PORT=25
MAIL_SMTP_SECURE=false
MAIL_SMTP_IGNORE_TLS=true
MAIL_FROM=admin@life-kline.com
MAIL_PASSWORD=
MAIL_FROM_NAME=人生K线
EMAIL_APP_NAME=人生K线
NEXT_PUBLIC_APP_URL=https://www.life-kline.com
ENABLE_AGENTIC_PIPELINE=1
DEFAULT_MODEL=gpt-5.2
MODEL_FALLBACK_CHAIN=gpt-5.2,grok-420-fast,auto
LLM_HEALTH_WINDOW_MINUTES=30
LLM_CIRCUIT_OPEN_MIN_ATTEMPTS=6
LLM_CIRCUIT_OPEN_FAILURE_RATE=0.7
LLM_CIRCUIT_DEGRADE_FAILURE_RATE=0.45
LLM_CIRCUIT_RECOVER_FAILURE_RATE=0.35
LLM_CIRCUIT_OPEN_CONSECUTIVE_FAILURES=4
LLM_CIRCUIT_RECOVERY_SUCCESS_STREAK=2
