# Copy to production only: /home/life-kline-next/.secrets/r2-backup.env (chmod 600)
# Never commit real values to git.

R2_BUCKET=life-kline-backup
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Remote path prefix: <SERVER_IP>/<PROJECT_NAME>/<DATE>/
R2_SERVER_IP=167.160.188.70
R2_PROJECT_NAME=life-kline-next

# Backup cadence (script checks elapsed days when invoked by daily cron)
R2_BACKUP_INTERVAL_DAYS=3

# Local staging before upload
R2_BACKUP_LOCAL_DIR=/var/backups/life-kline-r2
R2_BACKUP_KEEP_LOCAL_DAYS=14