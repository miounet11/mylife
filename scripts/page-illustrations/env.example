# Copy to a non-git path, e.g.:
#   /home/life-kline-next/.secrets/page-illustrations.env  (prod, chmod 600)
#   or export in local shell only
#
# NEVER commit real keys.
#
# 所有图像模型统一走聚合中转站 inping：

PAGE_ILLUST_API_BASE=https://ttqq.inping.com
PAGE_ILLUST_API_KEY=

# Primary image model for textures / fast assets
PAGE_ILLUST_MODEL_TURBO=grok-imagine-image-lite
PAGE_ILLUST_MODEL_COMPLEX=gpt-image-2

# Shared LLM image client (lib/llm-image-client.ts)
LLM_IMAGE_PRIMARY_BASE_URL=https://ttqq.inping.com/v1
LLM_IMAGE_PRIMARY_MODEL=grok-imagine-image-lite
LLM_IMAGE_PRIMARY_API_KEY=
FENGSHUI_TEXTURE_MODEL=grok-imagine-image-lite
